# ── Railway Production Environment ──
# Copy these values into Railway service variables
# Do NOT commit this file with real values

# Runtime
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://your-app.up.railway.app
APP_PAYMENT_CALLBACK_URL=https://your-app.up.railway.app/payments/callback

# Database (use Railway PostgreSQL plugin)
DATABASE_URL=postgresql://postgres:password@xxx.railway.app:5432/railway

# Redis (use Railway Redis plugin)
REDIS_URL=redis://default:password@xxx.railway.app:6379

# Auth / Crypto
JWT_ACCESS_SECRET=generate_random_32_chars_here
JWT_REFRESH_SECRET=generate_random_32_chars_here
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
ENCRYPTION_KEY=generate_base64_32_bytes_here
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# OTP (Firebase default; set OTP_PROVIDER=termii for SMS gateways)
OTP_PROVIDER=firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=hiconnect-3caf8
# Web API key from Firebase Console → Project settings → General (browser Phone Auth)
FIREBASE_WEB_API_KEY=
PUSH_ENABLED=true

# SMS fallback (only when OTP_PROVIDER=termii)
TERMII_API_KEY=
TERMII_SENDER_ID=HiGo
TERMII_BASE_URL=https://api.ng.termii.com
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=HiGo

# Cloudflare R2 (KYC document storage)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=higo-kyc-docs
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_PLAN_DAILY=PLN_xxxxx
PAYSTACK_PLAN_WEEKLY=PLN_xxxxx
PAYSTACK_PLAN_MONTHLY=PLN_xxxxx
PLATFORM_COMMISSION_RATE=0.10

# Maps
GOOGLE_MAPS_API_KEY=xxxxx
MAPS_DIRECTIONS_ENABLED=true

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=HiGo <noreply@hiconnect.com>
WEEKLY_KPI_EMAIL_RECIPIENTS=ceo@hiconnect.com
WEEKLY_MARKETING_SPEND_KOBO=0
WEEKLY_OPERATING_COSTS_KOBO=0
CRON_JOBS_ENABLED=true

# Observability
SENTRY_DSN=https://xxxxx.ingest.sentry.io/xxxxx
DATADOG_API_KEY=xxxxx

# AI (OpenRouter)
OPENROUTER_API_KEY=xxxxx
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Mobile (Expo)
EXPO_PUBLIC_API_BASE_URL=https://your-app.up.railway.app
EXPO_PUBLIC_SOCKET_URL=https://your-app.up.railway.app
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=xxxxx
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx