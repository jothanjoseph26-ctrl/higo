# ---- Runtime ----
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
APP_PAYMENT_CALLBACK_URL=http://localhost:3000/payments/callback

# ---- Database / Cache ----
DATABASE_URL=postgresql://higo:higo_dev_password@localhost:5433/higo?schema=public
REDIS_URL=redis://localhost:6379

# ---- Auth / Crypto ----
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ---- OTP (Firebase default; set OTP_PROVIDER=termii to use SMS gateways) ----
OTP_PROVIDER=firebase
FIREBASE_SERVICE_ACCOUNT_PATH=hiconnect-firebase-services-key.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_SERVER_KEY=
# Push notifications (defaults on when Firebase credentials are present; set false to disable)
PUSH_ENABLED=false

# ---- SMS fallback (only when OTP_PROVIDER=termii) ----
TERMII_API_KEY=
TERMII_SENDER_ID=HiGo
TERMII_BASE_URL=https://api.ng.termii.com
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=HiGo

# ---- Cloudflare R2 (object storage for KYC docs) ----
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_BUCKET=higo-kyc-docs
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=

# ---- Paystack ----
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_PLAN_DAILY=PLN_xxxxx
PAYSTACK_PLAN_WEEKLY=PLN_xxxxx
PAYSTACK_PLAN_MONTHLY=PLN_xxxxx
PLATFORM_COMMISSION_RATE=0.10
SURGE_ENABLED=false

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY=xxxxx
MAPS_DIRECTIONS_ENABLED=true

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=HiGo <noreply@hiconnect.com>

# ---- Observability ----
SENTRY_DSN=
DATADOG_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ---- Mobile (Expo public) ----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=xxxxx
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
EXPO_PUBLIC_SENTRY_DSN=