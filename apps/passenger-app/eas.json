{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_MAPS_MOCK": "false",
        "EXPO_PUBLIC_PUSH_MOCK": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
